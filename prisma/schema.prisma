generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "libsql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String    @unique
  passwordHash  String?
  handle        String?   @unique // Public handle like @username
  bio           String?

  // Profile
  isVerified    Boolean   @default(false)
  region        String?
  walletAddress String?

  // Stats
  wins          Int       @default(0)
  losses        Int       @default(0)
  totalEarnings Float     @default(0)

  // Preferences
  isAnonymous   Boolean   @default(false)

  // Relations
  challengesCreated Beef[]   @relation("Challenger")
  challengesAccepted Beef[]  @relation("Responder")
  sidecards     Sidecard[]
  ratings       Rating[]
  following     Follow[]   @relation("Follower")
  followers     Follow[]   @relation("Following")
  threadImports ThreadImport[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Beef {
  id            String    @id @default(cuid())

  // Claim
  claim         String    // The statement being debated
  category      String    // POLITICS, CULTURE, SPORTS, TECH, CALLOUTS
  debateType    String    // PERSUASION, OBJECTIVE_CLAIM, TASTE_BATTLE

  // Participants
  challengerId  String
  challenger    User      @relation("Challenger", fields: [challengerId], references: [id])
  responderId   String?
  responder     User?     @relation("Responder", fields: [responderId], references: [id])

  // Stakes
  ante          Float     // Entry amount ($10, $25, $50, $100)
  totalPot      Float     // Total pot (challenger + responder ante)

  // Timing
  startedAt     DateTime?
  endsAt        DateTime? // 24 hours from match

  // Status
  status        String    @default("OPEN") // OPEN, MATCHED, LIVE, JUDGING, COMPLETED, APPEALED

  // Judging
  judgeType     String?   // PANEL_OF_3_MODELS, COMMUNITY, EXPERT
  winnerId      String?
  judgeRubric   String?   // JSON of scoring criteria
  judgeDecision String?   // Text explanation
  appealStatus  String?   // null, APPEALED, APPEAL_DENIED, APPEAL_ACCEPTED

  // Metadata
  viewCount     Int       @default(0)
  sideVolume    Float     @default(0) // Total sidecard volume

  // Relations
  rounds        Round[]
  sidecards     Sidecard[]
  ratings       Rating[]
  threadImport  ThreadImport?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Round {
  id            String    @id @default(cuid())

  beefId        String
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  roundNumber   Int       // 1 (OPENING), 2 (RECEIPTS), 3 (CLOSING)
  roundType     String    // OPENING, RECEIPTS, CLOSING

  // Content
  challengerContent String?
  responderContent  String?

  // Evidence/Receipts
  challengerEvidence String? // JSON array of links/screenshots
  responderEvidence  String? // JSON array of links/screenshots

  // Timing
  submittedAt   DateTime  @default(now())

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([beefId, roundNumber])
}

model Sidecard {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  beefId        String
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  // Prediction
  predictedWinnerId String
  stake         Float     // Amount wagered

  // Categories
  category      String?   // FIRE, FACTS, RECKLESS

  // Payout
  payout        Float?    // Calculated after beef resolves
  isPaid        Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Rating {
  id            String    @id @default(cuid())

  beefId        String
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  raterId       String
  rater         User      @relation(fields: [raterId], references: [id])

  ratedUserId   String    // Who is being rated

  score         Int       // 1-5 stars
  comment       String?

  createdAt     DateTime  @default(now())

  @@unique([beefId, raterId])
}

model Follow {
  id            String    @id @default(cuid())

  followerId    String
  follower      User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId   String
  following     User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@unique([followerId, followingId])
}

model ThreadImport {
  id            String    @id @default(cuid())

  beefId        String    @unique
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  // Source
  platform      String    // TWITTER, DISCORD, REDDIT, FOURCHAN
  sourceUrl     String    // Original thread URL
  threadData    String    // JSON of scraped thread content

  // Participants
  participants  String    // JSON array of usernames from original thread

  createdAt     DateTime  @default(now())
}

model Transaction {
  id            String    @id @default(cuid())

  userId        String
  type          String    // ANTE, SIDECARD, PAYOUT, REFUND
  amount        Float
  status        String    // PENDING, COMPLETED, FAILED

  relatedBeefId String?
  relatedSidecardId String?

  // Payment provider data
  paymentProvider String? // STRIPE, etc
  paymentId     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
