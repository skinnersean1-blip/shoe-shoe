// Prisma schema for The Urban Playground (Shoe Shoe Marketplace)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth models (NextAuth) ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique  // e.g. @hypebeast_99
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?   // Profile bio / tagline
  creditBalance Int       @default(0)   // SS Points
  role          UserRole  @default(USER)
  trustScore    Float     @default(5.0) // 0-5 trust rating
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  shoesListed        Shoe[]              @relation("SellerShoes")
  purchases          Transaction[]       @relation("BuyerTransactions")
  sales              Transaction[]       @relation("SellerTransactions")
  ratingsGiven       Rating[]            @relation("RatingsGiven")
  ratingsReceived    Rating[]            @relation("RatingsReceived")
  notifications      Notification[]
  creditTransactions CreditTransaction[]
  sentMessages       Message[]           @relation("SentMessages")
  receivedMessages   Message[]           @relation("ReceivedMessages")
  disputes           Dispute[]           @relation("DisputeUser")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

// ─── Shoe listing ──────────────────────────────────────────────────────────

model Shoe {
  id          String @id @default(cuid())
  sellerId    String
  seller      User   @relation("SellerShoes", fields: [sellerId], references: [id], onDelete: Cascade)

  // Core details
  brand       String
  year        Int
  color       String
  size        String        // e.g. "5C", "7Y", "4C-7Y" for pairs
  ageGroup    AgeGroup?     // BABY / TODDLER / YOUTH
  condition   Condition
  description String
  price       Float
  images      String        // JSON array of base64 or URLs

  // Listing type
  type        ShoeType      // SINGLE or PAIR
  listingType ListingType   @default(SELL) // SELL / TRADE / DONATE
  creditValue Int           @default(0)    // Credits earned/required for trade

  // Status & moderation
  status           ShoeStatus        @default(AVAILABLE)
  moderationStatus ModerationStatus  @default(PENDING_REVIEW)
  moderatedBy      String?           // Admin user ID who reviewed
  moderatedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

enum ShoeType {
  SINGLE
  PAIR
}

enum AgeGroup {
  BABY    // 0C-4C
  TODDLER // 5C-10C
  YOUTH   // 11C-7Y
}

enum Condition {
  NEW       // Deadstock / Brand New
  LIKE_NEW  // VNDS / Lightly Worn
  GOOD      // Well-Loved
  FAIR
  WORN
}

enum ShoeStatus {
  AVAILABLE
  PENDING_SALE
  SOLD
}

enum ListingType {
  SELL
  TRADE
  DONATE
}

enum ModerationStatus {
  PENDING_REVIEW
  APPROVED
  FLAGGED
  REJECTED
}

// ─── Transaction ───────────────────────────────────────────────────────────

model Transaction {
  id       String @id @default(cuid())
  shoeId   String
  shoe     Shoe   @relation(fields: [shoeId], references: [id], onDelete: Cascade)

  buyerId  String?
  buyer    User?   @relation("BuyerTransactions", fields: [buyerId], references: [id])

  sellerId String
  seller   User    @relation("SellerTransactions", fields: [sellerId], references: [id])

  // Transaction details
  status       TransactionStatus @default(PENDING)
  type         TransactionType   @default(CASH) // CASH or TRADE
  offerPrice   Float?
  finalPrice   Float
  serviceFee   Float             @default(0.99)
  creditsUsed  Int               @default(0)    // For trade transactions

  // Guest buyer info
  buyerEmail String?
  buyerName  String?

  // Shipping
  shippingMethod  String?
  trackingNumber  String?
  trackingStatus  ShippingStatus?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings       Rating[]
  notifications Notification[]
  messages      Message[]
  disputes      Dispute[]
}

enum TransactionStatus {
  PENDING           // Initial buyer interest
  COUNTEROFFER      // Seller made counteroffer
  ACCEPTED          // Offer accepted
  PAYMENT_PENDING   // Awaiting payment
  PAID              // Payment received
  LABEL_PRINTED     // Shipping label generated
  DROPPED_OFF       // Package with carrier
  SHIPPED           // In transit
  DELIVERED         // Buyer confirmed delivery
  COMPLETED         // Transaction complete with rating
  CANCELLED         // Cancelled
  DISPUTED          // Under dispute resolution
}

enum TransactionType {
  CASH
  TRADE
  DONATION
}

enum ShippingStatus {
  LABEL_PRINTED
  DROPPED_OFF
  IN_TRANSIT
  DELIVERED
}

// ─── Rating ────────────────────────────────────────────────────────────────

model Rating {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  raterId     String
  rater       User   @relation("RatingsGiven", fields: [raterId], references: [id])

  ratedUserId String
  ratedUser   User   @relation("RatingsReceived", fields: [ratedUserId], references: [id])

  rating  Int     // 1-5 stars
  comment String?

  createdAt DateTime @default(now())

  @@unique([transactionId, raterId])
}

// ─── Notification ──────────────────────────────────────────────────────────

model Notification {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  type    NotificationType
  title   String
  message String
  read    Boolean          @default(false)

  createdAt DateTime @default(now())
}

enum NotificationType {
  SALE_INITIATED
  COUNTEROFFER_RECEIVED
  OFFER_ACCEPTED
  PAYMENT_RECEIVED
  LABEL_READY
  SHIPMENT_CONFIRMED
  DELIVERY_CONFIRMED
  RATING_RECEIVED
  TRADE_OFFER_RECEIVED
  TRADE_COMPLETED
  NEW_DROP
  MODERATION_APPROVED
  MODERATION_FLAGGED
}

// ─── Credits ───────────────────────────────────────────────────────────────

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int    // positive = earned, negative = spent
  reason      String // Human-readable description
  shoeId      String?
  transactionId String?

  createdAt DateTime @default(now())
}

// ─── Messaging ─────────────────────────────────────────────────────────────

model Message {
  id         String @id @default(cuid())
  senderId   String
  sender     User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  content       String
  read          Boolean      @default(false)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Disputes ──────────────────────────────────────────────────────────────

model Dispute {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  reporterId String
  reporter   User   @relation("DisputeUser", fields: [reporterId], references: [id])

  reason      DisputeReason
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?       // Admin notes on resolution
  resolvedBy  String?       // Admin user ID
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DisputeReason {
  ITEM_NOT_AS_DESCRIBED
  PAYMENT_FAILED
  COUNTERFEIT_SUSPECTED
  NOT_RECEIVED
  SELLER_UNRESPONSIVE
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_SELLER
  RESOLVED_BUYER
  RESOLVED_SPLIT
}

// ─── System Config (live ops) ──────────────────────────────────────────────

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String

  updatedAt DateTime  @updatedAt
  updatedBy String?   // Admin user ID
}
