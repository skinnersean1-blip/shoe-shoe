generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String    @unique
  passwordHash  String?
  handle        String?   @unique
  bio           String?

  isVerified    Boolean   @default(false)
  region        String?
  walletAddress String?

  wins          Int       @default(0)
  losses        Int       @default(0)
  totalEarnings Float     @default(0)

  isAnonymous   Boolean   @default(false)

  challengesCreated  Beef[]    @relation("Challenger")
  challengesAccepted Beef[]    @relation("Responder")
  messages           Message[]
  sidecards          Sidecard[]
  ratings            Rating[]
  following          Follow[]  @relation("Follower")
  followers          Follow[]  @relation("Following")
  threadImports      ThreadImport[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Beef {
  id            String    @id @default(cuid())

  claim         String
  categories    String    @default("[]") // JSON array: ["POLITICS","TECH"]

  challengerId  String
  challenger    User      @relation("Challenger", fields: [challengerId], references: [id])
  responderId   String?
  responder     User?     @relation("Responder", fields: [responderId], references: [id])

  ante          Float
  totalPot      Float

  startedAt     DateTime?
  endsAt        DateTime? // 24 hours from when match is accepted

  status        String    @default("OPEN") // OPEN, LIVE, JUDGING, COMPLETED

  winnerId      String?
  judgeDecision String?   // LLM verdict text
  appealStatus  String?

  viewCount     Int       @default(0)
  sideVolume    Float     @default(0)

  messages      Message[]
  sidecards     Sidecard[]
  ratings       Rating[]
  threadImport  ThreadImport?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())

  beefId    String
  beef      Beef     @relation(fields: [beefId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  content   String

  createdAt DateTime @default(now())
}

model Sidecard {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  beefId        String
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  predictedWinnerId String
  stake         Float

  payout        Float?
  isPaid        Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Rating {
  id            String    @id @default(cuid())

  beefId        String
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  raterId       String
  rater         User      @relation(fields: [raterId], references: [id])

  ratedUserId   String

  score         Int
  comment       String?

  createdAt     DateTime  @default(now())

  @@unique([beefId, raterId])
}

model Follow {
  id            String    @id @default(cuid())

  followerId    String
  follower      User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId   String
  following     User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@unique([followerId, followingId])
}

model ThreadImport {
  id            String    @id @default(cuid())

  beefId        String    @unique
  beef          Beef      @relation(fields: [beefId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  platform      String
  sourceUrl     String
  threadData    String
  participants  String

  createdAt     DateTime  @default(now())
}

model Transaction {
  id            String    @id @default(cuid())

  userId        String
  type          String    // ANTE, SIDECARD, PAYOUT, REFUND
  amount        Float
  status        String    // PENDING, COMPLETED, FAILED

  relatedBeefId     String?
  relatedSidecardId String?

  paymentProvider String?
  paymentId       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
